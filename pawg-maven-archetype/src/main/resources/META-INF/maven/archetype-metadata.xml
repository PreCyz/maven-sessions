<archetype-descriptor xsi:schemaLocation="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0 http://maven.apache.org/xsd/archetype-descriptor-1.1.0.xsd"
    xmlns="http://maven.apache.org/plugins/maven-archetype-plugin/archetype-descriptor/1.1.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    name="hexagonal-module">

  <requiredProperties>
    <requiredProperty key="applicationDescription">
      <defaultValue>Module following hexagonal principles.</defaultValue>
    </requiredProperty>
  </requiredProperties>

  <fileSets>
    <fileSet filtered="true" encoding="UTF-8">
      <directory></directory>
      <includes>
        <include>README.md</include>
      </includes>
    </fileSet>
  </fileSets>

  <modules>
    <module id="core" dir="core" name="core">
      <fileSets>
        <fileSet filtered="true" packaged="true">
          <directory>src/main/java</directory>
        </fileSet>
      </fileSets>
    </module>
    <module id="in-port" dir="in-port" name="in-port">
      <fileSets>
        <fileSet filtered="true" packaged="true">
          <directory>src/main/java</directory>
        </fileSet>
      </fileSets>
    </module>
    <module id="in-adapter" dir="in-adapter" name="in-adapter">
      <fileSets>
        <fileSet filtered="true" packaged="true">
          <directory>src/main/java</directory>
        </fileSet>
      </fileSets>
    </module>
    <module id="out-adapter" dir="out-adapter" name="out-adapter">
      <fileSets>
        <fileSet filtered="true" packaged="true">
          <directory>src/main/java</directory>
        </fileSet>
      </fileSets>
    </module>
    <module id="app" dir="app" name="app">
      <fileSets>
        <fileSet filtered="true" packaged="true">
          <directory>src/main/java</directory>
        </fileSet>
        <fileSet filtered="true">
          <directory>src/main/resources</directory>
        </fileSet>
      </fileSets>
    </module>
  </modules>
</archetype-descriptor>
